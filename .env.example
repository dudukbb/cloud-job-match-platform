# Factor III — Store config in the environment
# Copy this file to .env and fill in real values. Never commit .env to version control.

FLASK_ENV=development

# Security
SECRET_KEY=change-me-to-a-long-random-string

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobmatch

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# App settings
LOG_LEVEL=INFO
JOBS_PER_PAGE=10
SESSION_LIFETIME=3600
PORT=5000
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60

# Deployment behavior
AUTO_CREATE_TABLES=true
TRUST_PROXY=false
REQUIRE_STRONG_SECRET=false

# Postgres (used by docker-compose)
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobmatch
